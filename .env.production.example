# =============================================================================
# PLACEMENT360 — RAILWAY PRODUCTION ENVIRONMENT VARIABLES
# =============================================================================
# Copy these into Railway → Your Service → Variables
# All values marked with <CHANGE_THIS> MUST be set before deploying
# =============================================================================

# ── App ───────────────────────────────────────────────────────────────────────
PROJECT_NAME=Placement360 Backend
VERSION=1.0.0
API_V1_STR=/api/v1
DEBUG=False
ENVIRONMENT=production
LOG_LEVEL=INFO

# ── Security ──────────────────────────────────────────────────────────────────
# Generate: python -c "import secrets; print(secrets.token_urlsafe(48))"
SECRET_KEY=<CHANGE_THIS_generate_64_char_random_string>
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=43200
REFRESH_TOKEN_EXPIRE_DAYS=7
BCRYPT_ROUNDS=12
ADMIN_SECRET=<CHANGE_THIS_strong_admin_password>

# ── Mock Auth — MUST be disabled in production ────────────────────────────────
ENABLE_MOCK_AUTH=false

# ── Database (Supabase) ───────────────────────────────────────────────────────
# Use the TRANSACTION POOLER (port 6543) for serverless / Railway deployments
DATABASE_URL=postgresql://postgres.<PROJECT_REF>:<PASSWORD>@aws-1-ap-northeast-2.pooler.supabase.com:6543/postgres
DB_POOL_SIZE=10
DB_MAX_OVERFLOW=10
DB_POOL_TIMEOUT=30
DB_POOL_RECYCLE=1800
DB_ECHO=False

# ── Supabase Auth ─────────────────────────────────────────────────────────────
SUPABASE_URL=https://<PROJECT_REF>.supabase.co
SUPABASE_ANON_KEY=<YOUR_SUPABASE_ANON_KEY>
SUPABASE_SERVICE_ROLE_KEY=<YOUR_SUPABASE_SERVICE_ROLE_KEY>
SUPABASE_JWT_SECRET=<YOUR_SUPABASE_JWT_SECRET>

# ── CORS — Add your Vercel URL here ──────────────────────────────────────────
# Format: comma-separated, no trailing slashes
ALLOWED_ORIGINS=https://<YOUR_APP>.vercel.app,https://<YOUR_CUSTOM_DOMAIN>
ALLOW_CREDENTIALS=True

# ── Redis (optional — Upstash recommended) ───────────────────────────────────
# Get a free Redis at https://upstash.com
REDIS_URL=redis://default:<PASSWORD>@<REGION>-redis.upstash.io:6379
CACHE_TTL_HOURS=12
REDIS_DECODE_RESPONSES=True

# ── AI Services ───────────────────────────────────────────────────────────────
AI_PROVIDER=openai
OPENAI_API_KEY=<YOUR_OPENAI_OR_OPENROUTER_KEY>
OPENAI_BASE_URL=https://openrouter.ai/api/v1
OPENAI_MODEL=openai/gpt-4o-mini
OPENAI_MAX_TOKENS=1000
OPENAI_TEMPERATURE=0.7
AI_MAX_REQUESTS_PER_DAY=100
AI_TIMEOUT_SECONDS=30

# ── Judge0 (Code Execution) ───────────────────────────────────────────────────
JUDGE0_API_KEY=<YOUR_RAPIDAPI_KEY>
JUDGE0_HOST=judge0-ce.p.rapidapi.com
JUDGE0_USE_HTTPS=True
JUDGE0_MAX_WAIT_TIME=10
JUDGE0_MAX_CPU_TIME=5
JUDGE0_MAX_MEMORY_KB=524288

# ── SendGrid (Email) ──────────────────────────────────────────────────────────
SENDGRID_API_KEY=<YOUR_SENDGRID_API_KEY>
SENDGRID_FROM_EMAIL=noreply@<YOUR_DOMAIN>
SENDGRID_FROM_NAME=Placement360 Platform

# ── External Platform Integrations ───────────────────────────────────────────
LEETCODE_API_URL=https://leetcode.com/graphql
LEETCODE_SESSION=<OPTIONAL_LEETCODE_SESSION_COOKIE>
CODEFORCES_API_URL=https://codeforces.com/api
CODEFORCES_API_KEY=<OPTIONAL>
CODEFORCES_API_SECRET=<OPTIONAL>
GITHUB_CLIENT_ID=<OPTIONAL>
GITHUB_CLIENT_SECRET=<OPTIONAL>
GITHUB_ACCESS_TOKEN=<OPTIONAL>
PLATFORM_FETCH_DELAY_SECONDS=2
PLATFORM_MAX_RETRIES=3

# ── Performance & Logging ─────────────────────────────────────────────────────
RATE_LIMIT_PER_MINUTE=100
RATE_LIMIT_BURST=150
EXTERNAL_API_TIMEOUT=10
EXTERNAL_API_RETRY_ATTEMPTS=3
SCHEDULER_TIMEZONE=Asia/Kolkata
MAX_UPLOAD_SIZE_MB=10
ALLOWED_FILE_EXTENSIONS=pdf,doc,docx,jpg,png,jpeg
STORAGE_BUCKET_RESUMES=resumes
STORAGE_BUCKET_ASSESSMENTS=assessments
STORAGE_BUCKET_PROFILE_PICS=profile-pictures

# ── Feature Flags ─────────────────────────────────────────────────────────────
ENABLE_AI_FEEDBACK=True
ENABLE_EXTERNAL_PLATFORMS=True
ENABLE_EMAIL_NOTIFICATIONS=True
ENABLE_WEB_SCRAPING=True
MOCK_JUDGE0=False
MOCK_OPENAI=False
MOCK_SENDGRID=False
