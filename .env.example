PROJECT_NAME=Placement360 Backend
VERSION=1.0.0
API_V1_STR=/api/v1
DEBUG=True
ENVIRONMENT=development

DATABASE_URL=postgresql://postgres.[PROJECT-REF]:[PASSWORD]@[HOST]:6543/postgres
DB_ECHO=False
DB_POOL_SIZE=10
DB_MAX_OVERFLOW=20
DB_POOL_TIMEOUT=30

REDIS_URL=redis://default:[PASSWORD]@[HOST]:6379
CACHE_TTL_HOURS=12
REDIS_DECODE_RESPONSES=True

SECRET_KEY=generate-with-python-secrets
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7
BCRYPT_ROUNDS=12

ALLOWED_ORIGINS=http://localhost:3000,http://localhost:3001
ALLOW_CREDENTIALS=True

JUDGE0_API_KEY=get-from-rapidapi
JUDGE0_HOST=judge0-ce.p.rapidapi.com
JUDGE0_USE_HTTPS=True

AI_PROVIDER=openai
# AI_PROVIDER=claude
OPENAI_API_KEY=sk-proj-get-from-openai
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-4o-mini
ANTHROPIC_API_KEY=sk-ant-optional

SENDGRID_API_KEY=SG.get-from-sendgrid
SENDGRID_FROM_EMAIL=noreply@example.com
SENDGRID_FROM_NAME=Placement360 Platform

LEETCODE_SESSION=optional
GITHUB_CLIENT_ID=optional
GITHUB_CLIENT_SECRET=optional

RATE_LIMIT_PER_MINUTE=100
LOG_LEVEL=INFO
